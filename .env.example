# ============================================================================
# CodePilot AI — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your secrets:
#   cp .env.example .env
#
# NEVER commit .env to version control — it contains secrets.
# ============================================================================

# ---------- Server ----------
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
APP_ENVIRONMENT=development
LOG_LEVEL=debug

# ---------- Database (PostgreSQL) ----------
DB_HOST=postgres
DB_PORT=5432
DB_USER=codepilot
DB_PASSWORD=codepilot_secret
DB_NAME=codepilot
DB_SSL_MODE=disable

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379

# ---------- GitHub ----------
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret
GITHUB_MCP_IMAGE=ghcr.io/github/github-mcp-server

# ---------- LLM Provider ----------
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-api-key
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3
# Optional per-phase model tiering (cost optimization). Leave empty to use LLM_MODEL
# everywhere. Typically a cheap/fast model for triage & reflection, stronger for review.
LLM_TRIAGE_MODEL=
LLM_REVIEW_MODEL=
LLM_REFLECTION_MODEL=

# ---------- RAG (optional: semantic code retrieval) ----------
# When enabled, the review agent gains a retrieve_context tool backed by Qdrant +
# a local embeddings sidecar. Requires the qdrant + ollama compose services.
# First run: docker exec codepilot-ollama ollama pull nomic-embed-text
RAG_ENABLED=false
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=code_chunks
EMBEDDINGS_BASE_URL=http://ollama:11434/v1
EMBEDDINGS_MODEL=nomic-embed-text
EMBEDDINGS_API_KEY=
EMBEDDINGS_DIM=768
